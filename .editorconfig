# AI Foundation Kit — .editorconfig
# https://editorconfig.org

root = true


# --- Globales ---

[*]
charset                  = utf-8
end_of_line              = lf
indent_style             = space
indent_size              = 2
insert_final_newline     = true
trim_trailing_whitespace = true


# --- Markdown ---
# Deux espaces en fin de ligne = <br> en CommonMark.

[*.{md,mdx}]
trim_trailing_whitespace = false


# --- YAML ---

[*.{yml,yaml}]
indent_size = 2


# --- JSON ---

[*.{json,jsonc}]
indent_size = 2


# --- TOML ---

[*.toml]
indent_size = 2


# --- Python ---

[*.py]
indent_size = 4


# --- Shell ---

[*.sh]
indent_size = 2


# --- Docker ---

[{Dockerfile,*.dockerfile}]
indent_size = 4
